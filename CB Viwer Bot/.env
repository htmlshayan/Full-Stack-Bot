# Shared Redis config (main + workers)
REDIS_URL=redis://127.0.0.1:6379/0
REDIS_QUEUE_KEY=cb:queue
REDIS_EVENTS_CHANNEL=cb:events
REDIS_CONTROL_CHANNEL=cb:control
REDIS_WORKER_PREFIX=cb:worker:

# Database (PostgreSQL)
# NOTE: URL-encode special characters in the password.
DATABASE_URL=postgresql://postgres:%23beyservers%21@127.0.0.1:5432/bot

# Worker settings (only used by worker.py)
# Use a unique WORKER_ID per server or set it to "auto".
WORKER_ID=auto
WORKER_LABEL=auto
WORKER_MAX_PROFILES=10
WORKER_TILE_COLS=5
WORKER_HEARTBEAT_SECONDS=5
WORKER_HEARTBEAT_TTL=20
CHROME_VERSION_MAIN=auto

